# 服务监听端口
PORT=3000

# 站点 URL（用于 Cookie 等）
SITE_URL=http://localhost:3000

# 初始管理员账号（首次启动会写入数据库，之后不再生效）
ADMIN_USERNAME=admin
# 首次启动会随机生成；想固定就把注释打开
# ADMIN_PASSWORD=change-me-please

# 会话密钥（务必修改；生产环境不能使用默认值）
SESSION_SECRET=please-change-this-session-secret

# 日志保留天数（数据库 & 文件）
LOG_RETENTION_DAYS=30

# 登录限流（按 IP）—— 默认 5 次失败 / 10 分钟 → 锁 15 分钟
LOGIN_FAIL_WINDOW_MS=600000
LOGIN_FAIL_MAX=5
LOGIN_LOCK_MS=900000

# 验证接口限流（按 IP）—— 默认 600 次/分钟
VERIFY_RATE_LIMIT_PER_MIN=600

# 变量接口限流（按 IP）—— 默认 1200 次/分钟
VARIABLE_RATE_LIMIT_PER_MIN=1200

# Cookie secure 标记（HTTPS 下设为 1）
COOKIE_SECURE=0

# ===== 告警 Webhook =====
# 不配 = 禁用。配了就启用：短时间内大量失败验证会 POST 到这个 URL
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_THRESHOLD=30
ALERT_WEBHOOK_WINDOW_MS=60000
ALERT_COOLDOWN_MS=300000

